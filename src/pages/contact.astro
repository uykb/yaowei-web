---
import BaseLayout from '@layouts/BaseLayout.astro';

const lang = 'zh';
const t = (await import('@i18n/ui')).ui.zh;
---

<BaseLayout title={t.contact.title} lang={lang} currentPath="/contact">
  <!-- Page Header -->
  <section class="bg-gradient-to-br from-blue-900 to-blue-700 py-20">
    <div class="container mx-auto px-4 text-center">
      <h1 class="text-4xl md:text-5xl font-bold text-white mb-4">{t.contact.title}</h1>
      <div class="w-20 h-1 bg-white/50 mx-auto"></div>
    </div>
  </section>

  <!-- Contact Content -->
  <section class="py-20 bg-white">
    <div class="container mx-auto px-4">
      <div class="grid lg:grid-cols-2 gap-12">
        <!-- Contact Info -->
        <div>
          <h2 class="text-2xl font-bold text-gray-900 mb-8">{t.contact.title}</h2>
          
          <div class="space-y-6">
            <div class="flex items-start space-x-4">
              <div class="w-12 h-12 bg-blue-100 rounded-lg flex items-center justify-center flex-shrink-0">
                <svg class="w-6 h-6 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path>
                </svg>
              </div>
              <div>
                <h3 class="font-semibold text-gray-900">{t.contact.phone}</h3>
                <p class="text-gray-600">13710080413</p>
              </div>
            </div>

            <div class="flex items-start space-x-4">
              <div class="w-12 h-12 bg-blue-100 rounded-lg flex items-center justify-center flex-shrink-0">
                <svg class="w-6 h-6 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z"></path>
                </svg>
              </div>
              <div>
                <h3 class="font-semibold text-gray-900">{t.contact.mobile}</h3>
                <p class="text-gray-600">13710082243</p>
              </div>
            </div>

            <div class="flex items-start space-x-4">
              <div class="w-12 h-12 bg-blue-100 rounded-lg flex items-center justify-center flex-shrink-0">
                <svg class="w-6 h-6 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
                </svg>
              </div>
              <div>
                <h3 class="font-semibold text-gray-900">{t.contact.address}</h3>
                <div class="mt-2 space-y-2">
                  <div class="bg-gray-50 rounded-lg p-3">
                    <p class="text-sm font-medium text-gray-700">新和工厂</p>
                    <p class="text-gray-600 text-sm">广州市白云区钟落潭镇广从九路1019号</p>
                  </div>
                  <div class="bg-gray-50 rounded-lg p-3">
                    <p class="text-sm font-medium text-gray-700">鳌头工厂</p>
                    <p class="text-gray-600 text-sm">广州市从化区鳌头镇</p>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <!-- Factory Locations -->
          <div class="mt-8">
            <h3 class="text-lg font-bold text-gray-900 mb-4">{lang === 'zh' ? '工厂位置' : 'Factory Locations'}</h3>
            
            <!-- Location Tabs -->
            <div class="flex space-x-2 mb-4">
              <button class="location-tab active px-4 py-2 bg-blue-600 text-white text-sm rounded-lg font-medium transition" data-location="xinhe">
                {lang === 'zh' ? '新和工厂' : 'Xinhe Factory'}
              </button>
              <button class="location-tab px-4 py-2 bg-gray-100 text-gray-700 text-sm rounded-lg hover:bg-gray-200 transition font-medium" data-location="aotou">
                {lang === 'zh' ? '鳌头工厂' : 'Aotou Factory'}
              </button>
            </div>

            <!-- Xinhe Factory Map -->
            <div id="map-xinhe" class="map-container rounded-xl overflow-hidden hidden">
              <iframe 
                src="https://map.baidu.com/?newmap=1&ie=utf-8&s=s&wd=广州耀威包装有限公司新和工厂&from=mapshare" 
                width="100%" 
                height="300" 
                frameborder="0" 
                scrolling="no"
                class="w-full"
                loading="lazy"
                title="新和工厂地图">
              </iframe>
              <div class="bg-white p-4 border-t">
                <div class="flex items-start justify-between">
                  <div>
                    <h4 class="font-semibold text-gray-900">广州耀威包装有限公司(新和公司)</h4>
                    <p class="text-sm text-gray-600 mt-1">广州市白云区钟落潭镇广从九路1019号</p>
                  </div>
                </div>
                <div class="flex flex-wrap gap-2 mt-3">
                  <a href="https://uri.amap.com/search?query=广州耀威包装有限公司新和公司" target="_blank" rel="noopener" class="inline-flex items-center px-3 py-1.5 bg-green-50 text-green-700 text-sm rounded-lg hover:bg-green-100 transition">
                    <svg class="w-4 h-4 mr-1" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/></svg>
                    高德地图
                  </a>
                  <a href="https://map.baidu.com/search/广州耀威包装有限公司新和公司" target="_blank" rel="noopener" class="inline-flex items-center px-3 py-1.5 bg-blue-50 text-blue-700 text-sm rounded-lg hover:bg-blue-100 transition">
                    <svg class="w-4 h-4 mr-1" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/></svg>
                    百度地图
                  </a>
                  <a href="https://apis.map.qq.com/uri/v1/search?keyword=广州耀威包装有限公司新和公司" target="_blank" rel="noopener" class="inline-flex items-center px-3 py-1.5 bg-red-50 text-red-700 text-sm rounded-lg hover:bg-red-100 transition">
                    <svg class="w-4 h-4 mr-1" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/></svg>
                    腾讯地图
                  </a>
                </div>
              </div>
            </div>

            <!-- Aotou Factory Map -->
            <div id="map-aotou" class="map-container rounded-xl overflow-hidden">
              <iframe 
                src="https://map.baidu.com/?newmap=1&ie=utf-8&s=s&wd=广州耀威包装有限公司鳌头工厂&from=mapshare" 
                width="100%" 
                height="300" 
                frameborder="0" 
                scrolling="no"
                class="w-full"
                loading="lazy"
                title="鳌头工厂地图">
              </iframe>
              <div class="bg-white p-4 border-t">
                <div class="flex items-start justify-between">
                  <div>
                    <h4 class="font-semibold text-gray-900">广州耀威包装有限公司(鳌头公司)</h4>
                    <p class="text-sm text-gray-600 mt-1">广州市从化区鳌头镇</p>
                  </div>
                </div>
                <div class="flex flex-wrap gap-2 mt-3">
                  <a href="https://uri.amap.com/search?query=广州耀威包装有限公司鳌头公司" target="_blank" rel="noopener" class="inline-flex items-center px-3 py-1.5 bg-green-50 text-green-700 text-sm rounded-lg hover:bg-green-100 transition">
                    <svg class="w-4 h-4 mr-1" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/></svg>
                    高德地图
                  </a>
                  <a href="https://map.baidu.com/search/广州耀威包装有限公司鳌头公司" target="_blank" rel="noopener" class="inline-flex items-center px-3 py-1.5 bg-blue-50 text-blue-700 text-sm rounded-lg hover:bg-blue-100 transition">
                    <svg class="w-4 h-4 mr-1" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/></svg>
                    百度地图
                  </a>
                  <a href="https://apis.map.qq.com/uri/v1/search?keyword=广州耀威包装有限公司鳌头公司" target="_blank" rel="noopener" class="inline-flex items-center px-3 py-1.5 bg-red-50 text-red-700 text-sm rounded-lg hover:bg-red-100 transition">
                    <svg class="w-4 h-4 mr-1" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/></svg>
                    腾讯地图
                  </a>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Inquiry Form -->
        <div class="bg-gray-50 rounded-2xl p-8">
          <h2 class="text-2xl font-bold text-gray-900 mb-6">{lang === 'zh' ? '在线询盘' : 'Online Inquiry'}</h2>
          
          <form id="inquiry-form" class="space-y-5">
            <div>
              <label for="name" class="block text-sm font-medium text-gray-700 mb-2">{t.contact.form_name} *</label>
              <input type="text" id="name" name="name" required class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent outline-none transition" placeholder={t.contact.form_name} />
            </div>

            <div class="grid grid-cols-2 gap-4">
              <div>
                <label for="email" class="block text-sm font-medium text-gray-700 mb-2">{t.contact.form_email} *</label>
                <input type="email" id="email" name="email" required class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent outline-none transition" placeholder={t.contact.form_email} />
              </div>
              <div>
                <label for="phone" class="block text-sm font-medium text-gray-700 mb-2">{t.contact.form_phone}</label>
                <input type="tel" id="phone" name="phone" class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent outline-none transition" placeholder={t.contact.form_phone} />
              </div>
            </div>

            <div>
              <label for="company" class="block text-sm font-medium text-gray-700 mb-2">{t.contact.form_company}</label>
              <input type="text" id="company" name="company" class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent outline-none transition" placeholder={t.contact.form_company} />
            </div>

            <div>
              <label for="message" class="block text-sm font-medium text-gray-700 mb-2">{t.contact.form_message} *</label>
              <textarea id="message" name="message" rows="5" required class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent outline-none transition resize-none" placeholder={t.contact.form_message}></textarea>
            </div>

            <button type="submit" class="w-full bg-blue-600 text-white py-3 rounded-lg font-semibold hover:bg-blue-700 transition">
              {t.contact.form_submit}
            </button>
          </form>

          <div id="form-success" class="hidden mt-4 p-4 bg-green-50 text-green-700 rounded-lg">
            {lang === 'zh' ? '感谢您的询盘，我们会尽快与您联系！' : 'Thank you for your inquiry. We will contact you soon!'}
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  // Form submission
  const form = document.getElementById('inquiry-form');
  const successMsg = document.getElementById('form-success');
  
  if (form) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const formData = new FormData(form);
      console.log('Form submitted:', Object.fromEntries(formData));
      form.classList.add('hidden');
      successMsg.classList.remove('hidden');
    });
  }

  // Location tabs
  const tabs = document.querySelectorAll('.location-tab');
  const maps = document.querySelectorAll('.map-container');
  
  tabs.forEach(tab => {
    tab.addEventListener('click', () => {
      const location = tab.dataset.location;
      
      // Update tab styles
      tabs.forEach(t => {
        t.classList.remove('active', 'bg-blue-600', 'text-white');
        t.classList.add('bg-gray-100', 'text-gray-700');
      });
      tab.classList.add('active', 'bg-blue-600', 'text-white');
      tab.classList.remove('bg-gray-100', 'text-gray-700');
      
      // Show/hide maps
      maps.forEach(m => m.classList.add('hidden'));
      const targetMap = document.getElementById(`map-${location}`);
      if (targetMap) targetMap.classList.remove('hidden');
    });
  });
</script>
