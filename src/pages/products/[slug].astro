---
import BaseLayout from '@layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const products = await getCollection('products');
  return products.map(product => ({
    params: { slug: product.slug },
    props: { product },
  }));
}

const { product } = Astro.props;
const lang = 'zh';
const t = (await import('@i18n/ui')).ui.zh;
const categoryNames = {
  pe: t.products.categories.pe,
  pet: t.products.categories.pet,
  cap: t.products.categories.cap,
  pp: t.products.categories.pp,
  new: t.products.categories.new,
};
---

<BaseLayout title={product.data.title} lang={lang} currentPath={`/products/${product.slug}`}>
  <!-- Breadcrumb -->
  <section class="bg-gray-50 py-4">
    <div class="container mx-auto px-4">
      <nav class="text-sm text-gray-600">
        <a href="/" class="hover:text-blue-600">{t.nav.home}</a>
        <span class="mx-2">/</span>
        <a href="/products" class="hover:text-blue-600">{t.nav.products}</a>
        <span class="mx-2">/</span>
        <span class="text-gray-900">{product.data.title}</span>
      </nav>
    </div>
  </section>

  <!-- Product Detail -->
  <section class="py-16 bg-white">
    <div class="container mx-auto px-4">
      <div class="grid lg:grid-cols-2 gap-12">
        <!-- Product Image -->
        <div>
          <div class="aspect-square bg-gray-100 rounded-2xl flex items-center justify-center">
            {product.data.image ? (
              <img src={product.data.image} alt={product.data.title} class="w-full h-full object-cover rounded-2xl" />
            ) : (
              <span class="text-gray-400 text-lg">产品图片</span>
            )}
          </div>
        </div>

        <!-- Product Info -->
        <div>
          <span class="inline-block px-3 py-1 bg-blue-100 text-blue-600 text-sm rounded-full mb-4">
            {categoryNames[product.data.category]}
          </span>
          <h1 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">{product.data.title}</h1>
          <p class="text-gray-600 text-lg mb-8">{product.data.description}</p>

          <!-- Specifications -->
          {product.data.specifications && (
            <div class="mb-8">
              <h3 class="text-xl font-bold text-gray-900 mb-4">产品规格</h3>
              <div class="bg-gray-50 rounded-xl overflow-hidden">
                <table class="w-full">
                  <tbody>
                    {Object.entries(product.data.specifications).map(([key, value], index) => (
                      <tr class={index % 2 === 0 ? 'bg-gray-50' : 'bg-white'}>
                        <td class="px-4 py-3 text-gray-600 font-medium capitalize">{key}</td>
                        <td class="px-4 py-3 text-gray-900">{value}</td>
                      </tr>
                    ))}
                  </tbody>
                </table>
              </div>
            </div>
          )}

          <!-- CTA -->
          <div class="flex flex-wrap gap-4">
            <a href="/contact" class="bg-blue-600 text-white px-8 py-3 rounded-lg font-semibold hover:bg-blue-700 transition inline-block">
              {t.products.inquiry}
            </a>
            <a href="/products" class="border-2 border-gray-300 text-gray-700 px-8 py-3 rounded-lg font-semibold hover:border-blue-600 hover:text-blue-600 transition inline-block">
              {lang === 'zh' ? '返回产品列表' : 'Back to Products'}
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Product Content -->
  <section class="py-16 bg-gray-50">
    <div class="container mx-auto px-4">
      <div class="max-w-4xl mx-auto prose prose-lg">
        <slot />
      </div>
    </div>
  </section>
</BaseLayout>
