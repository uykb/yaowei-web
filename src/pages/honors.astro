---
import BaseLayout from '@layouts/BaseLayout.astro';

const lang = 'zh';
const t = (await import('@i18n/ui')).ui.zh;

const honors = [
  { title: 'QS生产许可证', year: '2014', desc: '食品相关产品生产许可证' },
  { title: 'ISO9001质量管理体系', year: '2015', desc: '国际质量管理体系认证' },
  { title: '高新技术企业', year: '2020', desc: '广东省高新技术企业认定' },
  { title: '环保认证', year: '2021', desc: '环保生产体系认证' },
  { title: '发明专利', year: '2022', desc: '多项包装设计专利' },
  { title: '出口资质', year: '2018', desc: '进出口经营权资质' },
];
---

<BaseLayout title={t.nav.honors} lang={lang} currentPath="/honors">
  <!-- Page Header -->
  <section class="bg-gradient-to-br from-blue-900 to-blue-700 py-20">
    <div class="container mx-auto px-4 text-center">
      <h1 class="text-4xl md:text-5xl font-bold text-white mb-4">{t.nav.honors}</h1>
      <div class="w-20 h-1 bg-white/50 mx-auto"></div>
    </div>
  </section>

  <!-- Honors Grid -->
  <section class="py-20 bg-white">
    <div class="container mx-auto px-4">
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
        {honors.map(honor => (
          <div class="bg-gray-50 rounded-xl p-6 text-center hover:shadow-lg transition">
            <div class="w-20 h-20 bg-blue-100 rounded-full flex items-center justify-center mx-auto mb-4">
              <svg class="w-10 h-10 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4M7.835 4.697a3.414 3.414 0 00-2.079 3.082c-.223 1.442-.543 2.882-.958 4.282a3.414 3.414 0 00.438 2.682c.44.712 1.155 1.14 1.958 1.14h13.596c.803 0 1.518-.428 1.958-1.14a3.414 3.414 0 00.438-2.682c-.415-1.4-.735-2.84-.958-4.282a3.414 3.414 0 00-2.079-3.082l-3.078-1.35a3.414 3.414 0 00-2.724 0l-3.078 1.35z"></path>
              </svg>
            </div>
            <h3 class="text-lg font-bold text-gray-900 mb-2">{honor.title}</h3>
            <p class="text-sm text-blue-600 mb-2">{honor.year}</p>
            <p class="text-gray-600 text-sm">{honor.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
