---
import BaseLayout from '@layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const lang = 'en';
const t = (await import('@i18n/ui')).ui.en;

const allNews = await getCollection('news');
const news = allNews.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<BaseLayout title={t.nav.news} lang={lang} currentPath="/news">
  <section class="bg-gradient-to-br from-blue-900 to-blue-700 py-20">
    <div class="container mx-auto px-4 text-center">
      <h1 class="text-4xl md:text-5xl font-bold text-white mb-4">{t.nav.news}</h1>
      <div class="w-20 h-1 bg-white/50 mx-auto"></div>
    </div>
  </section>

  <section class="py-20 bg-gray-50">
    <div class="container mx-auto px-4">
      <div class="grid md:grid-cols-2 gap-8">
        {news.map(item => (
          <article class="bg-white rounded-xl overflow-hidden shadow-sm hover:shadow-lg transition">
            <div class="p-6">
              <div class="flex items-center space-x-3 mb-3">
                <span class="px-3 py-1 bg-blue-100 text-blue-600 text-sm rounded-full">{item.data.category}</span>
                <span class="text-gray-400 text-sm">{item.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</span>
              </div>
              <h3 class="text-xl font-bold text-gray-900 mb-3 hover:text-blue-600 transition">
                <a href={`/en/news/${item.slug}`}>{item.data.title}</a>
              </h3>
              <p class="text-gray-600 mb-4">{item.data.excerpt}</p>
              <a href={`/en/news/${item.slug}`} class="text-blue-600 font-medium hover:text-blue-700 transition">
                Read More →
              </a>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
