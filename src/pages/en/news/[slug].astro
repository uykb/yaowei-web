---
import BaseLayout from '@layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const news = await getCollection('news');
  return news.map(item => ({
    params: { slug: item.slug },
    props: { item },
  }));
}

const { item } = Astro.props;
const lang = 'en';
const t = (await import('@i18n/ui')).ui.en;
---

<BaseLayout title={item.data.title} lang={lang} currentPath={`/news/${item.slug}`}>
  <section class="bg-gray-50 py-4">
    <div class="container mx-auto px-4">
      <nav class="text-sm text-gray-600">
        <a href="/en" class="hover:text-blue-600">{t.nav.home}</a>
        <span class="mx-2">/</span>
        <a href="/en/news" class="hover:text-blue-600">{t.nav.news}</a>
        <span class="mx-2">/</span>
        <span class="text-gray-900">{item.data.title}</span>
      </nav>
    </div>
  </section>

  <section class="bg-gradient-to-br from-blue-900 to-blue-700 py-16">
    <div class="container mx-auto px-4">
      <div class="max-w-4xl mx-auto">
        <div class="flex items-center space-x-3 mb-4">
          <span class="px-3 py-1 bg-white/20 text-white text-sm rounded-full">{item.data.category}</span>
          <span class="text-blue-200 text-sm">{item.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</span>
        </div>
        <h1 class="text-3xl md:text-4xl font-bold text-white mb-4">{item.data.title}</h1>
        <p class="text-xl text-blue-100">{item.data.excerpt}</p>
      </div>
    </div>
  </section>

  <section class="py-16 bg-white">
    <div class="container mx-auto px-4">
      <div class="max-w-4xl mx-auto prose prose-lg">
        <slot />
      </div>
    </div>
  </section>
</BaseLayout>
